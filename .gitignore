# ==============================================================================
# GLOBAL/ROOT GITIGNORE - Agricultural Dashboard (Node.js + React + Python ML)
# ==============================================================================

# ------------------------------------------------------------------------------
# Dependencies
# ------------------------------------------------------------------------------
node_modules/
backend/node_modules/
frontend/node_modules/

# ------------------------------------------------------------------------------
# Environment Variables & Secrets (CRITICAL: Never commit these!)
# ------------------------------------------------------------------------------
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
backend/.env
frontend/.env

# ------------------------------------------------------------------------------
# Python & Machine Learning Caches / Virtual Envs
# ------------------------------------------------------------------------------
# Byte-compiled / optimized / DLL files
__pycache__/
backend/ml/__pycache__/
*.py[cod]
*$py.class

# Virtual Environments
venv/
.venv/
env/
ENV/
backend/venv/
backend/.venv/
backend/env/

# Jupyter Notebook checkpoints
.ipynb_checkpoints/

# ------------------------------------------------------------------------------
# Frontend Build Outputs
# ------------------------------------------------------------------------------
frontend/build/
frontend/dist/
frontend/coverage/

# ------------------------------------------------------------------------------
# Dynamic User Uploads (Ignore actual uploads, keep the folder structure)
# ------------------------------------------------------------------------------
backend/uploads/*
!backend/uploads/.gitkeep

# ------------------------------------------------------------------------------
# IDEs and Editor Configuration
# ------------------------------------------------------------------------------
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.swp

# ------------------------------------------------------------------------------
# OS and Diagnostics Logs
# ------------------------------------------------------------------------------
.DS_Store
Thumbs.db
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ------------------------------------------------------------------------------
# Agent / Scratchpad Files
# ------------------------------------------------------------------------------
scratch/
