# =============================================
# BACKEND ENVIRONMENT VARIABLES
# Copy this file to .env and fill in the values
# NEVER commit the actual .env file to GitHub!
# =============================================

# MongoDB Connection String (from MongoDB Atlas)
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/agriShare?retryWrites=true&w=majority

# JWT Secret Key (generate a long random string, e.g. 64+ characters)
JWT_SECRET=your_super_secret_jwt_key_here

# Node Environment
NODE_ENV=production

# Google OAuth (for Calendar integration)
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=https://your-render-backend-url.onrender.com/api/google/callback

# Email (for automatic Calendar invites / notifications)
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_gmail_app_password

# Super Admin Credentials (for seeding admin account)
SUPER_ADMIN_EMAIL=admin@example.com
SUPER_ADMIN_PASS=your_admin_password

# Frontend URL (for CORS - set this to your deployed frontend URL)
FRONTEND_URL=https://your-frontend.vercel.app
